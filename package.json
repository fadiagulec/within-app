{
  "name": "soma",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:web": "expo export -p web && node scripts/patch-dist-html.js",
    "eas:init": "npx eas-cli@latest init",
    "eas:build:preview": "npx eas-cli@latest build --profile preview --platform all",
    "eas:build:production": "npx eas-cli@latest build --profile production --platform all",
    "eas:submit:ios": "npx eas-cli@latest submit --platform ios",
    "eas:submit:android": "npx eas-cli@latest submit --platform android"
  },
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.2.3",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/jetbrains-mono": "^0.2.3",
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@tanstack/react-query": "^5.59.0",
    "circular-natal-horoscope-js": "^1.1.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.0",
    "expo-av": "~15.0.0",
    "expo-constants": "~17.0.0",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.0",
    "expo-image": "~2.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.0",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "sharp": "^0.34.5",
    "typescript": "~5.3.3"
  },
  "private": true
}
