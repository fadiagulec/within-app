{
  "expo": {
    "name": "Within",
    "slug": "within-me",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "withinme",
    "userInterfaceStyle": "light",
    "backgroundColor": "#D6C7A8",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#D6C7A8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.soma.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Within records optional voice journal entries when you choose to add them.",
        "NSPhotoLibraryUsageDescription": "Within lets you add images to your vision board from your photo library."
      },
      "associatedDomains": ["applinks:soma.app"]
    },
    "android": {
      "package": "com.soma.app",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D6C7A8"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "soma" }],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "soma.app" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Within to access your microphone for voice journal entries."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "soma"
  }
}
